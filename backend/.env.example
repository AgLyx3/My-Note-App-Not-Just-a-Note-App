PORT=3001
OPENAI_API_KEY=
# Optional override; defaults to gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini
# Optional override for ranking lab synthetic generation; defaults to OPENAI_MODEL or gpt-4o-mini
OPENAI_LAB_MODEL=gpt-4o-mini
# Optional token required for /v1/metrics/* endpoints when set
DASHBOARD_TOKEN=
# Optional; defaults to text-embedding-3-small (placement suggestions)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
